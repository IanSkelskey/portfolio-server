# Port the server listens on (Render sets this automatically)
PORT=3000

# Your Resend API key — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# The email address that receives contact form submissions
CONTACT_TO_EMAIL=you@example.com

# Set to "development" locally to also allow localhost:5173 via CORS
NODE_ENV=development

# Comma-separated extra origins to allow (e.g. for local dev)
# EXTRA_ORIGINS=http://localhost:5173,http://localhost:4173
